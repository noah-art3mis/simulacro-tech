---
import { Menu, X } from 'lucide-astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];

const homeHref = getLocalizedPath('/', lang);
const aboutHref = getLocalizedPath('/about', lang);
const projectsHref = getLocalizedPath('/projects', lang);
const contactHref = `${homeHref.replace(/\/$/, '')}/#contact`;

const navItems = [
	{ href: homeHref, label: t('nav.home') },
	{ href: projectsHref, label: t('nav.projects') },
	{ href: aboutHref, label: t('nav.about') },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/92 backdrop-blur-md border-b border-[var(--color-rule)]">
	<div class="container-shell">
		<div class="flex justify-between items-center h-16 lg:h-20">
			<a href={homeHref} class="group flex items-baseline gap-3">
				<span class="text-base lg:text-lg font-semibold tracking-[-0.02em]">
					simulacro<span class="text-[var(--color-text-muted)]">.tech</span>
				</span>
			</a>

			<!-- Desktop Navigation -->
			<div class="hidden md:flex items-center gap-10">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="text-sm tracking-[-0.01em] text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors link-underline"
							data-path={item.href}
						>
							{item.label}
						</a>
					))
				}
				<a
					href={contactHref}
					class="btn btn-outline-light text-xs"
				>
					{t('nav.contact')}
				</a>
				<div class="pl-5 border-l border-[var(--color-rule)]">
					<LanguageSwitcher lang={lang} />
				</div>
			</div>

			<!-- Mobile menu button -->
			<button
				type="button"
				class="md:hidden p-2 text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
				id="mobile-menu-button"
				aria-label="Toggle menu"
				aria-expanded="false"
			>
				<Menu size={22} id="menu-icon" />
				<X size={22} id="close-icon" class="hidden" />
			</button>
		</div>
	</div>

	<!-- Mobile Navigation -->
	<div
		class="md:hidden border-t border-[var(--color-rule)] bg-[var(--color-bg-elevated)] overflow-hidden mobile-menu"
		id="mobile-menu"
	>
		<div class="container-shell py-6 space-y-1">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="block py-3 text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors text-base font-medium tracking-[-0.01em]"
						data-path={item.href}
					>
						{item.label}
					</a>
				))
			}
			<a
				href={contactHref}
				class="btn btn-outline-light mt-5 w-full justify-center"
			>
				{t('nav.contact')}
			</a>
			<div class="pt-6 mt-3 border-t border-[var(--color-rule)]">
				<LanguageSwitcher lang={lang} />
			</div>
		</div>
	</div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-16 lg:h-20"></div>

<style>
	.mobile-menu {
		max-height: 0;
		opacity: 0;
		transition:
			max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.3s ease;
	}
	.mobile-menu.is-open {
		max-height: 480px;
		opacity: 1;
	}
</style>

<script>
	const menuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');

	if (menuButton && mobileMenu && menuIcon && closeIcon) {
		menuButton.addEventListener('click', () => {
			const open = mobileMenu.classList.toggle('is-open');
			menuButton.setAttribute('aria-expanded', String(open));
			menuIcon.classList.toggle('hidden', open);
			closeIcon.classList.toggle('hidden', !open);
		});
	}

	const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
	document.querySelectorAll('[data-path]').forEach((link) => {
		const linkPath = (link.getAttribute('data-path') || '').replace(/\/$/, '') || '/';
		if (linkPath === currentPath) {
			link.classList.add('text-[var(--color-text)]');
			link.classList.remove('text-[var(--color-text-muted)]');
			link.classList.add('is-active');
		}
	});
</script>
