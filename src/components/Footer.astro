---
import { Mail, MapPin, Phone, FileText, BookOpen, GraduationCap } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
	buildDate?: string;
}

const { lang, buildDate } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
const homeHref = getLocalizedPath('/', lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-auto bg-[var(--color-bg-elevated)]/50 relative overflow-hidden">
	<!-- A whisper of warm light along the top — keeps the warmth thesis -->
	<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/30 to-transparent"></div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 pt-20 pb-10">
		<div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 pb-12 border-b border-[var(--color-border)]">
			<!-- Brand -->
			<div class="md:col-span-5">
				<a href={homeHref} class="flex items-center gap-3 mb-4">
					<img
						src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/simulacro.png`}
						alt="Simulacro"
						width="32"
						height="32"
						loading="lazy"
						decoding="async"
						class="w-8 h-8"
					/>
					<span class="text-lg font-semibold tracking-tight">
						simulacro<span class="text-[var(--color-text-muted)]">.tech</span>
					</span>
				</a>
				<p class="text-sm text-[var(--color-text-muted)] max-w-xs leading-relaxed">
					{t('footer.tagline')}
				</p>
			</div>

			<!-- Contact -->
			<div class="md:col-span-4">
				<h3 class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-accent)] mb-5">
					{t('footer.contact.heading')}
				</h3>
				<div class="space-y-3">
					<a
						href="mailto:contact@simulacro.tech"
						class="flex items-center gap-3 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
					>
						<Mail size={15} class="shrink-0" />
						contact@simulacro.tech
					</a>
					<a
						href="tel:+5561981334405"
						class="flex items-center gap-3 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
					>
						<Phone size={15} class="shrink-0" />
						+55 61 98133-4405
					</a>
					<div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
						<MapPin size={15} class="shrink-0" />
						{t('footer.contact.location')}
					</div>
				</div>
			</div>

			<!-- Connect -->
			<div class="md:col-span-3">
				<h3 class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-accent)] mb-5">
					{t('footer.connect.heading')}
				</h3>
				<div class="flex gap-3">
					<a
						href="https://linkedin.com/in/gustavoarcos"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/50 transition-all duration-300"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="17"
							height="17"
							viewBox="0 0 24 24"
							fill="currentColor"
						>
							<path
								d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
							></path>
						</svg>
					</a>
					<a
						href="https://github.com/noah-art3mis"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub"
						class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/50 transition-all duration-300"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="17"
							height="17"
							viewBox="0 0 24 24"
							fill="currentColor"
						>
							<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
						</svg>
					</a>
					<a
						href="https://simulacro.cv"
						target="_blank"
						rel="noopener noreferrer"
						aria-label={t('about.links.cv')}
						class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/50 transition-all duration-300"
					>
						<FileText size={17} />
					</a>
					<a
						href="https://simulacro.co.uk"
						target="_blank"
						rel="noopener noreferrer"
						aria-label={t('about.links.essays')}
						class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/50 transition-all duration-300"
					>
						<BookOpen size={17} />
					</a>
					<a
						href="https://gustavocosta.psc.br"
						target="_blank"
						rel="noopener noreferrer"
						aria-label={t('about.links.philosophy')}
						class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/50 transition-all duration-300"
					>
						<GraduationCap size={17} />
					</a>
				</div>
			</div>
		</div>

		<!-- ─── Signoff line ─── -->
		<div class="pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
			<p>&copy; {year} Simulacro Tech · {t('footer.copyright')}</p>
			{buildDate && (
				<p class="flex items-center gap-2">
					<span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]/60"></span>
					<span>{t('footer.build.label')} · {buildDate}</span>
				</p>
			)}
		</div>
	</div>
</footer>
