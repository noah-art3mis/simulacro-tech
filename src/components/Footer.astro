---
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
	buildDate?: string;
}

const { lang, buildDate } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
const homeHref = getLocalizedPath('/', lang);
const year = new Date().getFullYear();
---

<footer class="block block-dark border-t border-[var(--color-rule-strong)] mt-auto">
	<div class="container-shell py-16 lg:py-24">
		<!-- Top: closing statement, full-width statement type -->
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 pb-16 border-b border-[var(--color-rule)]">
			<div class="lg:col-span-7">
				<p class="text-statement leading-[0.96] tracking-[-0.035em] text-balance max-w-3xl">
					{t('footer.tagline')}
				</p>
			</div>

			<div class="lg:col-span-5 lg:pl-10 lg:border-l lg:border-[var(--color-rule)]">
				<p class="mono-label mb-8">{t('footer.contact.heading')}</p>
				<ul class="space-y-4 text-base lg:text-lg">
					<li>
						<a
							href="mailto:contact@simulacro.tech"
							class="link-underline text-[var(--color-text)]"
						>
							contact@simulacro.tech
						</a>
					</li>
					<li>
						<a
							href="tel:+5561981334405"
							class="link-underline text-[var(--color-text-muted)]"
						>
							+55 61 98133-4405
						</a>
					</li>
					<li class="text-[var(--color-text-muted)]">
						{t('footer.contact.location')}
					</li>
				</ul>

				<p class="mono-label mb-5 mt-12">{t('footer.connect.heading')}</p>
				<div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
					<a
						href="https://linkedin.com/in/gustavoarcos"
						target="_blank"
						rel="noopener noreferrer"
						class="link-underline text-[var(--color-text-muted)]"
					>
						LinkedIn
					</a>
					<a
						href="https://github.com/noah-art3mis"
						target="_blank"
						rel="noopener noreferrer"
						class="link-underline text-[var(--color-text-muted)]"
					>
						GitHub
					</a>
					<a
						href="https://simulacro.cv"
						target="_blank"
						rel="noopener noreferrer"
						class="link-underline text-[var(--color-text-muted)]"
					>
						{t('about.links.cv')}
					</a>
					<a
						href="https://simulacro.co.uk"
						target="_blank"
						rel="noopener noreferrer"
						class="link-underline text-[var(--color-text-muted)]"
					>
						{t('about.links.essays')}
					</a>
					<a
						href="https://gustavocosta.psc.br"
						target="_blank"
						rel="noopener noreferrer"
						class="link-underline text-[var(--color-text-muted)]"
					>
						{t('about.links.philosophy')}
					</a>
				</div>
			</div>
		</div>

		<!-- Bottom: brand, signoff -->
		<div class="pt-10 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
			<a href={homeHref} class="inline-block">
				<span class="text-2xl lg:text-3xl font-semibold tracking-[-0.03em]">
					simulacro<span class="text-[var(--color-text-muted)]">.tech</span>
				</span>
			</a>

			<div class="flex flex-col lg:flex-row lg:items-center gap-3 lg:gap-8 mono-label opacity-80">
				<span>&copy; {year} · {t('footer.copyright')}</span>
				{buildDate && (
					<span class="flex items-center gap-2">
						<span class="w-1 h-1 rounded-full bg-[var(--color-amber)]"></span>
						{t('footer.build.label')} · {buildDate}
					</span>
				)}
			</div>
		</div>
	</div>
</footer>
