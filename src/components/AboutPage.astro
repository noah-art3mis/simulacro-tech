---
import { GraduationCap, Briefcase, ExternalLink } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
---

<!-- Hero -->
<section class="relative py-24 overflow-hidden">
	<div class="gradient-orb gradient-orb-1"></div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
		<div class="max-w-3xl">
			<span
				class="text-sm font-medium text-[var(--color-accent)] uppercase tracking-wider mb-4 block animate-fade-up"
			>
				{t('about.label')}
			</span>
			<h1 class="text-5xl md:text-6xl font-bold mb-8 animate-fade-up animate-delay-1">
				Gustavo Costa
			</h1>
			<p
				class="text-xl text-[var(--color-text-muted)] leading-relaxed animate-fade-up animate-delay-2"
			>
				{t('about.subtitle')}
			</p>
		</div>
	</div>
</section>

<!-- Bio Section -->
<section class="py-16">
	<div class="max-w-6xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
			<div class="lg:col-span-2 space-y-6">
				<p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
					{t('about.bio.p1')}
				</p>
				<p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
					{t('about.bio.p2')}
				</p>
				<p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
					{t('about.bio.p3')}
				</p>
			</div>

			<div class="lg:col-span-1">
				<div class="glass-card rounded-2xl p-6 sticky top-28">
					<h3 class="font-semibold mb-4 text-[var(--color-accent)]">
						{t('about.links.heading')}
					</h3>
					<div class="space-y-3">
						<a
							href="https://simulacro.cv"
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center justify-between text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors group"
						>
							<span>{t('about.links.cv')}</span>
							<ExternalLink
								size={14}
								class="opacity-0 group-hover:opacity-100 transition-opacity"
							/>
						</a>
						<a
							href="https://simulacro.co.uk"
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center justify-between text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors group"
						>
							<span>{t('about.links.essays')}</span>
							<ExternalLink
								size={14}
								class="opacity-0 group-hover:opacity-100 transition-opacity"
							/>
						</a>
						<a
							href="https://gustavocosta.psc.br"
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center justify-between text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors group"
						>
							<span>{t('about.links.philosophy')}</span>
							<ExternalLink
								size={14}
								class="opacity-0 group-hover:opacity-100 transition-opacity"
							/>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Education & Experience -->
<section class="py-24">
	<div class="max-w-6xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- Education -->
			<div class="glass-card rounded-2xl p-8">
				<div class="flex items-center gap-4 mb-8">
					<div class="icon-box">
						<GraduationCap size={24} />
					</div>
					<h2 class="text-2xl font-bold">{t('about.education.heading')}</h2>
				</div>

				<div class="space-y-6">
					<div class="border-l-2 border-[var(--color-accent)]/30 pl-6">
						<h3 class="font-semibold mb-1">{t('about.education.degree1.title')}</h3>
						<p class="text-sm text-[var(--color-text-muted)]">London Interdisciplinary School</p>
					</div>
					<div class="border-l-2 border-[var(--color-border)] pl-6">
						<h3 class="font-semibold mb-1">{t('about.education.degree2.title')}</h3>
						<p class="text-sm text-[var(--color-text-muted)]">Faculdade Inspirar</p>
					</div>
					<div class="border-l-2 border-[var(--color-border)] pl-6">
						<h3 class="font-semibold mb-1">{t('about.education.degree3.title')}</h3>
						<p class="text-sm text-[var(--color-text-muted)]">Universidade de Brasília</p>
					</div>
				</div>
			</div>

			<!-- Experience -->
			<div class="glass-card rounded-2xl p-8">
				<div class="flex items-center gap-4 mb-8">
					<div class="icon-box">
						<Briefcase size={24} />
					</div>
					<h2 class="text-2xl font-bold">{t('about.experience.heading')}</h2>
				</div>

				<div class="space-y-6">
					<div class="border-l-2 border-[var(--color-accent)]/30 pl-6">
						<h3 class="font-semibold mb-1">{t('about.experience.psychotherapy.title')}</h3>
						<p class="text-sm text-[var(--color-text-muted)]">
							{t('about.experience.psychotherapy.details')}
						</p>
						<p class="text-xs text-[var(--color-text-muted)] mt-1">2020 – 2024</p>
					</div>
					<div class="border-l-2 border-[var(--color-border)] pl-6">
						<h3 class="font-semibold mb-1">{t('about.experience.writing.title')}</h3>
						<p class="text-sm text-[var(--color-text-muted)]">
							{t('about.experience.writing.details')}
						</p>
					</div>
					<div class="border-l-2 border-[var(--color-border)] pl-6">
						<h3 class="font-semibold mb-1">{t('about.experience.technical.title')}</h3>
						<p class="text-sm text-[var(--color-text-muted)]">
							{t('about.experience.technical.details')}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
