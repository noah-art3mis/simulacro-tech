---
import { Send } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
---

<div class="w-full max-w-2xl mx-auto">
	<form
		id="contact-form"
		action="https://formspree.io/f/xpwvlovb"
		class="glass-card-contact p-8 md:p-10 space-y-7"
		target="_top"
		method="POST"
		data-error-empty={t('form.error.empty')}
		data-error-email={t('form.error.email')}
		data-error-generic={t('form.error.generic')}
		data-error-network={t('form.error.network')}
	>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<div class="space-y-2">
				<label
					class="block font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-text-muted)]"
					for="name"
				>
					{t('form.name.label')}
				</label>
				<input
					class="field-input"
					id="name"
					name="name"
					type="text"
					placeholder={t('form.name.placeholder')}
					required
				/>
			</div>

			<div class="space-y-2">
				<label
					class="block font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-text-muted)]"
					for="email"
				>
					{t('form.email.label')}
				</label>
				<input
					class="field-input"
					id="email"
					name="email"
					type="email"
					placeholder={t('form.email.placeholder')}
					required
				/>
			</div>
		</div>

		<div class="space-y-2">
			<label
				class="block font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-text-muted)]"
				for="message"
			>
				{t('form.message.label')}
			</label>
			<textarea
				class="field-input field-textarea"
				id="message"
				name="message"
				placeholder={t('form.message.placeholder')}
				required></textarea>
		</div>

		<div class="flex justify-end pt-2">
			<button class="btn-primary inline-flex items-center gap-2 group" type="submit">
				{t('form.submit')}
				<Send size={16} class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
			</button>
		</div>
	</form>

	<div
		id="error"
		class="rounded-xl p-4 text-sm text-red-400 border border-red-400/30 bg-red-400/[0.03] hidden mt-6"
	>
	</div>

	<div id="success" class="rounded-xl p-8 text-center hidden mt-6 border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/[0.03]">
		<div
			class="w-16 h-16 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center mx-auto mb-4"
		>
			<svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M5 13l4 4L19 7"></path>
			</svg>
		</div>
		<p class="text-2xl mb-2 italic-serif">{t('form.success.title')}</p>
		<p class="text-sm text-[var(--color-text-muted)] mb-6">{t('form.success.subtext')}</p>
		<button
			type="button"
			id="send-another"
			class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-accent)] hover:underline underline-offset-4"
		>
			{t('form.success.action')}
		</button>
	</div>
</div>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement;
	const errorDiv = document.getElementById('error');
	const successDiv = document.getElementById('success');
	const sendAnotherBtn = document.getElementById('send-another');

	if (form && errorDiv && successDiv && sendAnotherBtn) {
		const msgEmpty = form.dataset.errorEmpty ?? 'Please fill in all fields.';
		const msgEmail = form.dataset.errorEmail ?? 'Please enter a valid email address.';
		const msgGeneric = form.dataset.errorGeneric ?? 'Something went wrong. Please try again.';
		const msgNetwork =
			form.dataset.errorNetwork ?? 'Network error. Please check your connection and try again.';

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			errorDiv.classList.add('hidden');
			successDiv.classList.add('hidden');

			const formData = new FormData(form);
			const name = formData.get('name') as string;
			const email = formData.get('email') as string;
			const message = formData.get('message') as string;

			if (!name || !email || !message) {
				errorDiv.textContent = msgEmpty;
				errorDiv.classList.remove('hidden');
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				errorDiv.textContent = msgEmail;
				errorDiv.classList.remove('hidden');
				return;
			}

			try {
				const response = await fetch(form.action, {
					method: 'POST',
					body: formData,
					headers: {
						Accept: 'application/json',
					},
				});

				if (response.ok) {
					const contentType = response.headers.get('content-type');
					if (contentType && contentType.includes('application/json')) {
						const data = await response.json();
						if (data.next || data.ok !== false) {
							form.classList.add('hidden');
							successDiv.classList.remove('hidden');
						} else {
							errorDiv.textContent = data.error || msgGeneric;
							errorDiv.classList.remove('hidden');
						}
					} else {
						form.classList.add('hidden');
						successDiv.classList.remove('hidden');
					}
				} else if (response.status === 302) {
					form.classList.add('hidden');
					successDiv.classList.remove('hidden');
				} else {
					try {
						const data = await response.json();
						errorDiv.textContent = data.error || msgGeneric;
					} catch {
						errorDiv.textContent = msgGeneric;
					}
					errorDiv.classList.remove('hidden');
				}
			} catch (error) {
				console.error('Form submission error:', error);
				errorDiv.textContent = msgNetwork;
				errorDiv.classList.remove('hidden');
			}
		});

		sendAnotherBtn.addEventListener('click', () => {
			form.reset();
			form.classList.remove('hidden');
			successDiv.classList.add('hidden');
			errorDiv.classList.add('hidden');
		});
	}
</script>
