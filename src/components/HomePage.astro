---
import ContactForm from './ContactForm.astro';
import { ArrowRight, Brain, BarChart3, Shield } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
const aboutHref = getLocalizedPath('/about', lang);
---

<!-- Hero Section -->
<section
	class="relative min-h-[90vh] flex items-center overflow-hidden hero-mesh-bg"
>
	<!-- Mesh gradient background -->
	<div
		class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_0%,rgba(245,158,11,0.15)_0%,transparent_50%),radial-gradient(ellipse_at_80%_100%,rgba(139,92,246,0.12)_0%,transparent_50%),radial-gradient(ellipse_at_50%_50%,rgba(239,68,68,0.08)_0%,transparent_60%)]"
	>
	</div>

	<!-- Animated glow orbs -->
	<div class="glow-orb w-[500px] h-[500px] -top-48 -right-48"></div>
	<div
		class="glow-orb glow-orb-secondary w-[400px] h-[400px] -bottom-32 -left-32"
		style="animation-delay: -2s;"
	>
	</div>
	<div
		class="glow-orb w-[300px] h-[300px] top-1/3 left-1/4 opacity-30"
		style="animation-delay: -1s;"
	>
	</div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 py-24 relative z-10">
		<div class="max-w-3xl">
			<h1 class="text-5xl md:text-7xl lg:text-8xl mb-8 animate-fade-up text-balance">
				{t('home.hero.title.before')}
				<span class="gradient-text">{t('home.hero.title.highlight')}</span>
			</h1>

			<p
				class="text-xl md:text-2xl text-[var(--color-text-muted)] mb-10 animate-fade-up animate-delay-1 max-w-2xl leading-relaxed"
			>
				{t('home.hero.tagline')}
			</p>

			<div class="animate-fade-up animate-delay-2">
				<a href="#contact" class="btn-primary inline-flex items-center justify-center gap-2 group">
					{t('home.hero.cta')}
					<ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
				</a>
			</div>
		</div>
	</div>

	<!-- Decorative element -->
	<div
		class="hidden lg:block absolute right-12 top-1/2 -translate-y-1/2 w-96 h-96 animate-float"
	>
		<div class="relative w-full h-full">
			<div
				class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)]/20 to-[var(--color-accent-secondary)]/10 rounded-full blur-2xl"
			>
			</div>
			<img
				src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/simulacro.png`}
				alt=""
				class="relative w-full h-full object-contain opacity-25 mix-blend-luminosity"
			/>
		</div>
	</div>
</section>

<!-- Services Section -->
<section id="services" class="py-20 relative">
	<div class="max-w-6xl mx-auto px-6 lg:px-8">
		<div class="text-center mb-20">
			<span
				class="text-sm font-medium text-[var(--color-accent)] uppercase tracking-wider mb-4 block"
			>
				{t('home.services.label')}
			</span>
			<h2 class="text-4xl md:text-5xl font-bold mb-6">{t('home.services.heading')}</h2>
			<p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
				{t('home.services.subheading')}
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<div class="glass-card rounded-2xl p-8 group">
				<div class="icon-box mb-6">
					<Brain size={24} />
				</div>
				<h3
					class="text-xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors"
				>
					{t('home.services.ai.title')}
				</h3>
				<p class="text-[var(--color-text-muted)] leading-relaxed">
					{t('home.services.ai.description')}
				</p>
			</div>

			<div class="glass-card rounded-2xl p-8 group">
				<div class="icon-box mb-6">
					<BarChart3 size={24} />
				</div>
				<h3
					class="text-xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors"
				>
					{t('home.services.data.title')}
				</h3>
				<p class="text-[var(--color-text-muted)] leading-relaxed">
					{t('home.services.data.description')}
				</p>
			</div>

			<div class="glass-card rounded-2xl p-8 group">
				<div class="icon-box mb-6">
					<Shield size={24} />
				</div>
				<h3
					class="text-xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors"
				>
					{t('home.services.ethics.title')}
				</h3>
				<p class="text-[var(--color-text-muted)] leading-relaxed">
					{t('home.services.ethics.description')}
				</p>
			</div>
		</div>
	</div>
</section>

<!-- Why Section -->
<section class="py-20 relative overflow-hidden">
	<div
		class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-bg-elevated)] to-transparent"
	>
	</div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
			<div>
				<span
					class="text-sm font-medium text-[var(--color-accent)] uppercase tracking-wider mb-4 block"
				>
					{t('home.why.label')}
				</span>
				<h2 class="text-4xl md:text-5xl font-bold mb-8">{t('home.why.heading')}</h2>
				<p class="text-lg text-[var(--color-text-muted)] mb-8 leading-relaxed">
					{t('home.why.intro')}
				</p>
			</div>

			<div class="space-y-6">
				<div class="glass-card rounded-xl p-6 flex gap-5">
					<div class="shrink-0">
						<div
							class="w-12 h-12 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] font-bold"
						>
							01
						</div>
					</div>
					<div>
						<h3 class="text-lg font-semibold mb-2">
							{t('home.why.clinical.title')}
						</h3>
						<p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
							{t('home.why.clinical.description')}
						</p>
					</div>
				</div>

				<div class="glass-card rounded-xl p-6 flex gap-5">
					<div class="shrink-0">
						<div
							class="w-12 h-12 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] font-bold"
						>
							02
						</div>
					</div>
					<div>
						<h3 class="text-lg font-semibold mb-2">
							{t('home.why.philosophy.title')}
						</h3>
						<p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
							{t('home.why.philosophy.description')}
						</p>
					</div>
				</div>

				<div class="glass-card rounded-xl p-6 flex gap-5">
					<div class="shrink-0">
						<div
							class="w-12 h-12 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] font-bold"
						>
							03
						</div>
					</div>
					<div>
						<h3 class="text-lg font-semibold mb-2">
							{t('home.why.technical.title')}
						</h3>
						<p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
							{t('home.why.technical.description')}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- About Preview -->
<section class="py-20 relative">
	<div class="max-w-6xl mx-auto px-6 lg:px-8">
		<div class="glass-card rounded-3xl p-10 md:p-16 relative overflow-hidden">
			<!-- Decorative glows -->
			<div
				class="glow-orb w-[400px] h-[400px] -top-32 -right-32 opacity-50"
				style="animation-delay: -0.5s;"
			>
			</div>
			<div
				class="glow-orb glow-orb-secondary w-[300px] h-[300px] -bottom-24 -left-24 opacity-40"
				style="animation-delay: -1.5s;"
			>
			</div>

			<div class="relative z-10 max-w-2xl">
				<span
					class="text-sm font-medium text-[var(--color-accent)] uppercase tracking-wider mb-4 block"
				>
					{t('home.about.label')}
				</span>
				<h2 class="text-3xl md:text-4xl mb-6">Gustavo Costa</h2>
				<p class="text-lg text-[var(--color-text-muted)] mb-8 leading-relaxed">
					{t('home.about.bio')}
				</p>
				<a
					href={aboutHref}
					class="inline-flex items-center gap-2 text-[var(--color-accent)] font-medium group transition-all duration-300"
				>
					{t('home.about.cta')}
					<ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
				</a>
			</div>
		</div>
	</div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-20 relative overflow-hidden">
	<div
		class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-elevated)] to-transparent"
	>
	</div>

	<!-- Decorative glow -->
	<div
		class="glow-orb glow-orb-secondary w-[500px] h-[500px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-20"
	>
	</div>

	<div class="max-w-4xl mx-auto px-6 lg:px-8 relative z-10">
		<div class="text-center mb-16">
			<span
				class="text-sm font-medium text-[var(--color-accent)] uppercase tracking-wider mb-4 block"
			>
				{t('home.contact.label')}
			</span>
			<h2 class="text-4xl md:text-5xl mb-6">{t('home.contact.heading')}</h2>
			<p class="text-lg text-[var(--color-text-muted)] max-w-xl mx-auto">
				{t('home.contact.subheading')}
			</p>
		</div>
		<ContactForm lang={lang} />
	</div>
</section>
