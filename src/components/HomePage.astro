---
import ContactForm from './ContactForm.astro';
import { ArrowUpRight } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
const aboutHref = getLocalizedPath('/about', lang);
const projectsHref = getLocalizedPath('/projects', lang);

const featuredProjects = [
	{ id: 'molcajete', name: 'Molcajete', taglineKey: 'projects.production.molcajete.tagline', preview: 'waveform' as const },
	{ id: 'adapta',    name: 'Adapta',    taglineKey: 'projects.production.adapta.tagline',    preview: 'sparkline' as const },
	{ id: 'judex',     name: 'Judex',     taglineKey: 'projects.openSource.judex.summary',     preview: 'highlight' as const },
] as const;

const services = [
	{ titleKey: 'home.services.ai.title',        descKey: 'home.services.ai.description' },
	{ titleKey: 'home.services.data.title',      descKey: 'home.services.data.description' },
	{ titleKey: 'home.services.pipelines.title', descKey: 'home.services.pipelines.description' },
] as const;

const approach = [
	{ id: 'clinical',   titleKey: 'home.why.clinical.title',   descKey: 'home.why.clinical.description'   },
	{ id: 'philosophy', titleKey: 'home.why.philosophy.title', descKey: 'home.why.philosophy.description' },
	{ id: 'technical',  titleKey: 'home.why.technical.title',  descKey: 'home.why.technical.description'  },
] as const;
---

<!-- ════════════════════════════════════════════════
     Hero — block-dark
     One statement, broken across lines. No italic.
     ════════════════════════════════════════════════ -->
<section class="block block-dark relative overflow-hidden">
	<!-- The single ambient orb. 9s pulse. -->
	<div class="glow-orb w-[640px] h-[640px] -bottom-40 -right-32"></div>

	<div class="container-shell pt-24 lg:pt-40 pb-32 lg:pb-48 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
			<div class="lg:col-span-2 mb-8 lg:mb-0">
				<p class="mono-label animate-fade-up">— Simulacro Tech</p>
			</div>

			<div class="lg:col-span-10 relative">
				<div class="construction-mark" aria-hidden="true">
					<svg viewBox="0 0 72 72">
						<line class="cm cm-h" x1="72" y1="72" x2="0"  y2="72" />
						<line class="cm cm-v" x1="72" y1="72" x2="72" y2="0"  />
					</svg>
				</div>
				<h1 class="text-mega text-balance">
					<span class="block animate-fade-up">{t('home.hero.line1')}</span>
					<span class="block animate-fade-up animate-delay-1">
						{t('home.hero.line2.before')}<span class="hero-emphasis text-[var(--color-amber)]">{t('home.hero.line2.highlight')}</span>{t('home.hero.line2.after')}
					</span>
				</h1>
			</div>
		</div>

		<div class="mt-20 lg:mt-32 grid grid-cols-1 lg:grid-cols-12 gap-10 items-end">
			<div class="lg:col-span-2 lg:col-start-3">
				<div class="rule-on-dark-strong w-12 mb-5"></div>
				<p class="mono-label">{t('home.services.label')}</p>
			</div>
			<div class="lg:col-span-7">
				<p class="text-xl lg:text-2xl text-[var(--color-text-muted)] leading-[1.4] tracking-[-0.015em] max-w-2xl text-pretty animate-fade-up animate-delay-2">
					{t('home.hero.tagline')}
				</p>
			</div>
			<div class="lg:col-span-3 flex lg:justify-end">
				<a href="#contact" class="btn btn-filled-amber animate-fade-up animate-delay-3 group">
					{t('home.hero.cta')}
					<ArrowUpRight size={16} class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
				</a>
			</div>
		</div>
	</div>

	<!-- Hard cut to the cream block below -->
	<div class="rule-on-dark-strong"></div>
</section>

<!-- ════════════════════════════════════════════════
     A position — block-cream
     The philosophical statement. Tight, Swiss.
     ════════════════════════════════════════════════ -->
<section class="block block-cream block-pad" id="position">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
			<div class="lg:col-span-3 mb-10 lg:mb-0">
				<p class="mono-label">— {t('eyebrow.position')}</p>
			</div>

			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-5xl">
					{t('home.services.heading')} —
					<span class="text-[var(--color-text-muted-on-light)]">{t('home.services.subheading')}</span>
				</h2>
			</div>
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     The work — block-dark
     Three work tiles. Hover = pure color swap to amber.
     ════════════════════════════════════════════════ -->
<section id="work" class="block block-dark block-pad scroll-mt-24">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('eyebrow.work')}</p>
			</div>
			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-4xl">
					{t('home.projects.heading')}.
				</h2>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[var(--color-rule-strong)]">
			{featuredProjects.map((p, i) => (
				<a
					href={`${projectsHref}#${p.id}`}
					class="group relative bg-[var(--color-bg)] hover:bg-[var(--color-amber)] transition-colors duration-500 ease-out flex flex-col min-h-[26rem]"
				>
					<div class="preview-frame">
						{p.preview === 'waveform' && (
							<div class="preview-waveform" aria-hidden="true">
								<span></span><span></span><span></span><span></span>
								<span></span><span></span><span></span><span></span>
								<span></span><span></span><span></span><span></span>
								<span></span><span></span><span></span><span></span>
							</div>
						)}
						{p.preview === 'sparkline' && (
							<div class="preview-sparkline" aria-hidden="true">
								<svg viewBox="0 0 300 100" preserveAspectRatio="none">
									<line class="grid" x1="0" y1="80" x2="300" y2="80" />
									<line class="grid" x1="0" y1="50" x2="300" y2="50" />
									<line class="grid" x1="0" y1="20" x2="300" y2="20" />
									{/* Training-loss curve — high at start, steep early descent, asymptotic flatten. */}
									<path class="area"  d="M 6 14 C 30 16, 50 30, 80 50 S 130 78, 170 86 S 230 92, 294 94 L 294 100 L 6 100 Z" />
									<path class="line"  d="M 6 14 C 30 16, 50 30, 80 50 S 130 78, 170 86 S 230 92, 294 94" />
									<circle class="dot" cx="294" cy="94" r="4" />
								</svg>
							</div>
						)}
						{p.preview === 'highlight' && (
							<div class="preview-highlight" aria-hidden="true">
								<span>STF · RE 1.234.567 / SP</span>
								<span>relator: <mark>min. relator</mark></span>
								<span>data: 2024-08-12 · trânsito em julgado</span>
								<span><mark>habeas corpus</mark> · matéria penal</span>
								<span>tribunal de origem: TJSP / 4ª câmara</span>
								<span>resultado: <mark>provimento parcial</mark></span>
							</div>
						)}
					</div>

					<div class="p-8 lg:p-10 flex flex-col grow">
						<div class="flex items-baseline justify-between mb-10">
							<span class="mono-num text-xs tracking-widest text-[var(--color-text-muted)] group-hover:text-[var(--color-bg)]/70 transition-colors duration-500">
								N° {String(i + 1).padStart(2, '0')}
							</span>
							<ArrowUpRight size={18} class="text-[var(--color-text-muted)] group-hover:text-[var(--color-bg)] transition-colors duration-500 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" style="transition-property: color, transform;" />
						</div>

						<h3 class="text-3xl lg:text-4xl font-semibold tracking-[-0.035em] leading-[0.95] mb-auto group-hover:text-[var(--color-bg)] transition-colors duration-500">
							{p.name}
						</h3>

						<p class="text-base text-[var(--color-text-muted)] leading-[1.5] mt-10 max-w-xs text-pretty group-hover:text-[var(--color-bg)]/80 transition-colors duration-500">
							{t(p.taglineKey as UIKey)}
						</p>
					</div>
				</a>
			))}
		</div>

		<div class="mt-12 flex justify-end">
			<a href={projectsHref} class="link-underline inline-flex items-center gap-2 text-[var(--color-text)] text-sm tracking-[-0.01em]">
				{t('home.projects.cta')}
				<ArrowUpRight size={14} />
			</a>
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     An approach — block-ink-blue
     Q&A. Three numbered rows, ruled list.
     ════════════════════════════════════════════════ -->
<section class="block block-ink-blue block-pad">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('eyebrow.approach')}</p>
			</div>
			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-4xl">
					{t('home.why.heading')} —
					<span class="opacity-70">{t('home.why.intro')}</span>
				</h2>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[rgba(236,229,211,0.16)]">
			{approach.map((row, i) => {
				const num = String(i + 1).padStart(2, '0');
				return (
					<article class="bg-[var(--color-ink-blue)] flex flex-col">
						<div class={`geom-frame geom-${row.id}`}>
							{row.id === 'clinical' && (
								<svg viewBox="0 0 300 180" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
									{/* Eclipse: amber disc + cream disc overlapping; amber-deep horizon line. */}
									<circle class="geom-fill-amber"            cx="118" cy="86"  r="62" />
									<circle class="geom-fill-cream blend"      cx="184" cy="100" r="42" />
									<rect   class="geom-fill-amber-deep"       x="40"  y="148"   width="220" height="3" />
									<rect   class="geom-fill-amber-deep"       x="40"  y="148"   width="14"  height="3" opacity="0" />
								</svg>
							)}
							{row.id === 'philosophy' && (
								<svg viewBox="0 0 300 180" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
									{/* Column + question. Cream pillar, amber circle balanced atop, amber-deep dot at base. */}
									<rect   class="geom-fill-cream"            x="78"  y="22"    width="38" height="138" />
									<circle class="geom-fill-amber blend"      cx="118" cy="42"  r="32" />
									<rect   class="geom-fill-amber-deep"       x="190" y="118"   width="44" height="44" />
									<rect   class="geom-fill-amber"            x="240" y="22"    width="3"  height="38" />
								</svg>
							)}
							{row.id === 'technical' && (
								<svg viewBox="0 0 300 180" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
									{/* Mondrian-tight composition. Four rectangles + a thin amber-deep rule. */}
									<rect class="geom-fill-amber"      x="30"  y="22"  width="108" height="78" />
									<rect class="geom-fill-cream"      x="148" y="22"  width="60"  height="38" />
									<rect class="geom-fill-amber-deep" x="148" y="68"  width="60"  height="92" />
									<rect class="geom-fill-cream"      x="218" y="22"  width="52"  height="58" opacity="0.55" />
									<rect class="geom-fill-amber"      x="218" y="88"  width="52"  height="72" />
									<rect class="geom-fill-amber-deep" x="30"  y="110" width="108" height="50" opacity="0.85" />
								</svg>
							)}
						</div>

						<div class="p-8 lg:p-10 flex flex-col grow">
							<span class="font-semibold text-4xl lg:text-5xl text-[var(--color-amber)] leading-none tracking-[-0.04em] mb-8">
								{num}
							</span>
							<h3 class="text-2xl lg:text-3xl font-semibold tracking-[-0.025em] leading-[1.05] mb-5">
								{t(row.titleKey)}
							</h3>
							<p class="text-base lg:text-lg leading-[1.5] opacity-80 text-pretty">
								{t(row.descKey)}
							</p>
						</div>
					</article>
				);
			})}
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     Elsewhere — block-amber
     About preview. The amber block earns one slot.
     ════════════════════════════════════════════════ -->
<section class="block block-amber block-pad-tight overflow-hidden">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center py-12 lg:py-20">
			<div class="lg:col-span-3 flex flex-col gap-6">
				<p class="mono-label">— {t('eyebrow.elsewhere')}</p>
				<div class="portrait-frame">
					<span class="portrait-mark">N° 01</span>
					<img
						src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/portrait.jpg`}
						alt="Gustavo Costa"
						width="349"
						height="465"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
			<div class="lg:col-span-7">
				<p class="text-2xl lg:text-3xl xl:text-4xl font-semibold tracking-[-0.03em] leading-[1.1] text-balance">
					{t('home.about.bio')}
				</p>
			</div>
			<div class="lg:col-span-2 flex lg:justify-end">
				<a href={aboutHref} class="btn btn-on-amber group">
					{t('home.about.cta')}
					<ArrowUpRight size={16} class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
				</a>
			</div>
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     Contact — block-dark
     Direct, conversational. Form has flat fields.
     ════════════════════════════════════════════════ -->
<section id="contact" class="block block-dark block-pad scroll-mt-24 relative overflow-hidden">
	<div class="glow-orb w-[520px] h-[420px] -bottom-32 left-1/4"></div>

	<div class="container-shell relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('home.contact.label')}</p>
			</div>
			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-3xl">
					{t('home.contact.heading')}
				</h2>
				<p class="mt-8 text-lg lg:text-xl text-[var(--color-text-muted)] max-w-2xl text-pretty">
					{t('home.contact.subheading')}
				</p>
			</div>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
			<div class="lg:col-span-3 lg:col-start-4">
				<!-- spacer to align form with heading -->
			</div>
			<div class="lg:col-span-9 lg:col-start-4">
				<ContactForm lang={lang} />
			</div>
		</div>
	</div>
</section>
