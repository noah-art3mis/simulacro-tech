---
import ContactForm from './ContactForm.astro';
import { ArrowRight, Brain, BarChart3, Workflow, HeartPulse, BookOpenText, Cpu } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
const aboutHref = getLocalizedPath('/about', lang);
const projectsHref = getLocalizedPath('/projects', lang);

const featuredProjects = [
	{ id: 'molcajete', name: 'Molcajete', taglineKey: 'projects.production.molcajete.tagline' },
	{ id: 'adapta',    name: 'Adapta',    taglineKey: 'projects.production.adapta.tagline' },
	{ id: 'judex', name: 'Judex', taglineKey: 'projects.openSource.judex.summary' },
] as const;
---

<!-- ─────────── Hero ─────────── -->
<!-- Strong glow. Choreographed entrance: eyebrow first, italic word last. -->
<section
	class="relative min-h-[92vh] flex items-center hero-mesh-bg"
>
	<!-- Mesh gradient background.
	     `in oklch` uses perceptual color interpolation (smoother across the visible range
	     than sRGB). Zero-alpha endpoints keep the fade in-hue instead of through black. -->
	<div
		class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_0%_in_oklch,rgba(245,158,11,0.18)_0%,rgba(245,158,11,0)_50%),radial-gradient(ellipse_at_80%_100%_in_oklch,rgba(139,92,246,0.13)_0%,rgba(139,92,246,0)_50%),radial-gradient(ellipse_at_50%_50%_in_oklch,rgba(239,68,68,0.07)_0%,rgba(239,68,68,0)_60%)] [mask-image:linear-gradient(to_bottom,black_60%,transparent_100%)] [filter:blur(40px)] [transform:scale(1.05)]"
	>
	</div>

	<!-- Animated glow orbs — hero gets the strongest atmosphere -->
	<div class="glow-orb w-[560px] h-[560px] -top-48 -right-48"></div>
	<div
		class="glow-orb glow-orb-secondary w-[420px] h-[420px] -bottom-32 -left-32"
		style="animation-delay: -2s;"
	>
	</div>
	<div
		class="hidden md:block glow-orb w-[260px] h-[260px] top-1/3 left-1/4 opacity-25"
		style="animation-delay: -1s;"
	>
	</div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 py-24 relative z-10 w-full">
		<div class="max-w-3xl">
			<span class="eyebrow mb-6 animate-fade-up">
				Simulacro Tech
			</span>

			<h1 class="text-[clamp(2.75rem,8vw,7.5rem)] leading-[0.95] mb-10 text-balance">
				<span class="animate-fade-up animate-delay-1 inline-block">
					{t('home.hero.title.before')}
				</span>
				<span class="italic-reveal italic-serif gradient-text">{t('home.hero.title.highlight')}</span>
			</h1>

			<p
				class="text-lg md:text-2xl text-[var(--color-text-muted)] mb-12 animate-fade-up animate-delay-2 max-w-2xl leading-relaxed text-pretty"
			>
				{t('home.hero.tagline')}
			</p>

			<div class="animate-fade-up animate-delay-3 flex items-center gap-6 flex-wrap">
				<a href="#contact" class="btn-primary btn-primary-pulse inline-flex items-center justify-center gap-2 group">
					{t('home.hero.cta')}
					<ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
				</a>
				<a href="#services" class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
					↓ scroll
				</a>
			</div>
		</div>
	</div>

	<!-- Decorative element -->
	<div
		class="hidden lg:block absolute right-12 top-1/2 -translate-y-1/2 w-96 h-96 animate-float pointer-events-none"
	>
		<div class="relative w-full h-full">
			<div
				class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)]/20 to-[var(--color-accent-secondary)]/10 rounded-full blur-2xl"
			>
			</div>
			<img
				src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/simulacro.png`}
				alt=""
				class="relative w-full h-full object-contain opacity-25 mix-blend-luminosity"
			/>
		</div>
	</div>
</section>

<!-- ─────────── Services ─────────── -->
<!-- Single subtle orb — quiet section after the hero blast. -->
<section id="services" class="py-24 md:py-28 relative scroll-mt-24">
	<div class="glow-orb w-[300px] h-[300px] -top-24 right-1/4 opacity-25" style="animation-delay: -2.5s;"></div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
		<div class="text-center max-w-3xl mx-auto mb-20">
			<span class="eyebrow mb-5 inline-block">01 — {t('home.services.label')}</span>
			<h2 class="text-[clamp(2rem,5vw,3.75rem)] mb-6 text-balance">{t('home.services.heading')}</h2>
			<p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed text-pretty">
				{t('home.services.subheading')}
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<div class="glass-card glass-card-service p-8 group stagger-child">
				<div class="icon-box mb-6">
					<Brain size={22} />
				</div>
				<h3 class="text-xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors">
					{t('home.services.ai.title')}
				</h3>
				<p class="text-[var(--color-text-muted)] leading-relaxed text-pretty">
					{t('home.services.ai.description')}
				</p>
			</div>

			<div class="glass-card glass-card-service p-8 group stagger-child">
				<div class="icon-box mb-6">
					<BarChart3 size={22} />
				</div>
				<h3 class="text-xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors">
					{t('home.services.data.title')}
				</h3>
				<p class="text-[var(--color-text-muted)] leading-relaxed text-pretty">
					{t('home.services.data.description')}
				</p>
			</div>

			<div class="glass-card glass-card-service p-8 group stagger-child">
				<div class="icon-box mb-6">
					<Workflow size={22} />
				</div>
				<h3 class="text-xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors">
					{t('home.services.pipelines.title')}
				</h3>
				<p class="text-[var(--color-text-muted)] leading-relaxed text-pretty">
					{t('home.services.pipelines.description')}
				</p>
			</div>
		</div>
	</div>
</section>

<!-- ─────────── Why ─────────── -->
<!-- Austere. NO orbs. The argument carries it. -->
<section class="py-24 md:py-32 relative">
	<div class="max-w-6xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
			<div class="lg:col-span-5">
				<span class="eyebrow mb-5 inline-block">02 — {t('home.why.label')}</span>
				<h2 class="text-[clamp(2rem,4.5vw,3.5rem)] mb-8 leading-[1.05]">{t('home.why.heading')}</h2>
				<p class="text-lg text-[var(--color-text-muted)] leading-relaxed text-pretty">
					{t('home.why.intro')}
				</p>

			</div>

			<div class="lg:col-span-7 space-y-5">
				<div class="glass-card glass-card-service p-6 md:p-7 flex gap-6 stagger-child">
					<div class="shrink-0">
						<div class="w-14 h-14 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)]" aria-hidden="true">
							<HeartPulse size={24} strokeWidth={1.5} />
						</div>
					</div>
					<div>
						<h3 class="text-xl mb-2 font-semibold">
							{t('home.why.clinical.title')}
						</h3>
						<p class="text-[var(--color-text-muted)] text-base leading-relaxed text-pretty">
							{t('home.why.clinical.description')}
						</p>
					</div>
				</div>

				<div class="glass-card glass-card-service p-6 md:p-7 flex gap-6 stagger-child">
					<div class="shrink-0">
						<div class="w-14 h-14 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)]" aria-hidden="true">
							<BookOpenText size={24} strokeWidth={1.5} />
						</div>
					</div>
					<div>
						<h3 class="text-xl mb-2 font-semibold">
							{t('home.why.philosophy.title')}
						</h3>
						<p class="text-[var(--color-text-muted)] text-base leading-relaxed text-pretty">
							{t('home.why.philosophy.description')}
						</p>
					</div>
				</div>

				<div class="glass-card glass-card-service p-6 md:p-7 flex gap-6 stagger-child">
					<div class="shrink-0">
						<div class="w-14 h-14 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)]" aria-hidden="true">
							<Cpu size={24} strokeWidth={1.5} />
						</div>
					</div>
					<div>
						<h3 class="text-xl mb-2 font-semibold">
							{t('home.why.technical.title')}
						</h3>
						<p class="text-[var(--color-text-muted)] text-base leading-relaxed text-pretty">
							{t('home.why.technical.description')}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ─────────── Projects ─────────── -->
<!-- Selected work — quiet glow, ruled cards, name leads. -->
<section id="projects" class="py-24 md:py-28 relative scroll-mt-24">
	<div class="glow-orb w-[280px] h-[280px] -bottom-20 left-1/4 opacity-20" style="animation-delay: -3.5s;"></div>

	<div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
		<div class="text-center max-w-3xl mx-auto mb-20">
			<span class="eyebrow mb-5 inline-block">03 — {t('home.projects.label')}</span>
			<h2 class="text-[clamp(2rem,5vw,3.75rem)] mb-6 text-balance">{t('home.projects.heading')}</h2>
			<p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed text-pretty">
				{t('home.projects.intro')}
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{featuredProjects.map((p, i) => (
				<a
					href={`${projectsHref}#${p.id}`}
					class="glass-card glass-card-case p-8 group stagger-child flex flex-col"
				>
					<div class="flex items-baseline gap-3 mb-6">
						<span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-accent)]">
							{String(i + 1).padStart(2, '0')}
						</span>
						<span class="flex-1 h-px bg-[var(--color-border)]"></span>
					</div>
					<h3 class="text-2xl font-semibold mb-4 group-hover:text-[var(--color-accent)] transition-colors">
						{p.name}
					</h3>
					<p class="text-[var(--color-text-muted)] leading-relaxed text-pretty flex-grow text-base">
						{t(p.taglineKey as UIKey)}
					</p>
				</a>
			))}
		</div>

		<div class="mt-14 flex justify-center">
			<a href={projectsHref} class="link-underline inline-flex items-center gap-2 font-medium text-[var(--color-accent)]">
				{t('home.projects.cta')}
				<ArrowRight size={16} class="transition-transform group-hover:translate-x-1" />
			</a>
		</div>
	</div>
</section>

<!-- ─────────── About preview ─────────── -->
<!-- Single subtle violet orb — slight warmth, not a blast. -->
<section class="py-20 relative">
	<div class="max-w-6xl mx-auto px-6 lg:px-8">
		<div class="glass-card glass-card-manifest p-10 md:p-16 relative overflow-hidden">
			<div
				class="glow-orb glow-orb-secondary w-[360px] h-[360px] -top-24 -right-24 opacity-35"
				style="animation-delay: -1.5s;"
			>
			</div>

			<div class="relative z-10 max-w-2xl">
				<span class="eyebrow mb-7 inline-block">04 — {t('home.about.label')}</span>
				<p class="text-xl md:text-2xl text-[var(--color-text-muted)] mb-8 leading-relaxed text-pretty">
					{t('home.about.bio')}
				</p>
				<a
					href={aboutHref}
					class="inline-flex items-center gap-2 text-[var(--color-accent)] font-medium group transition-all duration-300 link-underline"
				>
					{t('home.about.cta')}
					<ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
				</a>
			</div>
		</div>
	</div>
</section>

<!-- ─────────── Contact ─────────── -->
<!-- Warm bottom-glow. Form is almost-no-glass, see ContactForm. -->
<section id="contact" class="py-24 md:py-28 relative scroll-mt-24">
	<div
		class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-elevated)] to-transparent"
	>
	</div>

	<!-- Warm bottom glow — amber, not violet -->
	<div
		class="glow-orb w-[640px] h-[440px] -bottom-32 left-1/2 -translate-x-1/2 opacity-30"
	>
	</div>

	<div class="max-w-4xl mx-auto px-6 lg:px-8 relative z-10">
		<div class="text-center max-w-2xl mx-auto mb-14">
			<span class="eyebrow mb-5 inline-block">05 — {t('home.contact.label')}</span>
			<h2 class="text-[clamp(2rem,5vw,3.75rem)] mb-6 leading-[1.05] text-balance">
				{t('home.contact.heading')}
			</h2>
			<p class="text-lg text-[var(--color-text-muted)] text-pretty">
				{t('home.contact.subheading')}
			</p>
		</div>
		<ContactForm lang={lang} />
	</div>
</section>
