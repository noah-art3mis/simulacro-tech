---
import ContactForm from './ContactForm.astro';
import { ArrowUpRight } from 'lucide-astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = (key: UIKey) => ui[lang][key];
const aboutHref = getLocalizedPath('/about', lang);
const projectsHref = getLocalizedPath('/projects', lang);

const featuredProjects = [
	{ id: 'molcajete', name: 'Molcajete', taglineKey: 'projects.production.molcajete.tagline' },
	{ id: 'adapta',    name: 'Adapta',    taglineKey: 'projects.production.adapta.tagline' },
	{ id: 'judex',     name: 'Judex',     taglineKey: 'projects.openSource.judex.summary' },
] as const;

const services = [
	{ titleKey: 'home.services.ai.title',        descKey: 'home.services.ai.description' },
	{ titleKey: 'home.services.data.title',      descKey: 'home.services.data.description' },
	{ titleKey: 'home.services.pipelines.title', descKey: 'home.services.pipelines.description' },
] as const;

const approach = [
	{ titleKey: 'home.why.clinical.title',    descKey: 'home.why.clinical.description' },
	{ titleKey: 'home.why.philosophy.title',  descKey: 'home.why.philosophy.description' },
	{ titleKey: 'home.why.technical.title',   descKey: 'home.why.technical.description' },
] as const;
---

<!-- ════════════════════════════════════════════════
     Hero — block-dark
     One statement, broken across lines. No italic.
     ════════════════════════════════════════════════ -->
<section class="block block-dark relative overflow-hidden">
	<!-- The single ambient orb. 9s pulse. -->
	<div class="glow-orb w-[640px] h-[640px] -bottom-40 -right-32"></div>

	<div class="container-shell pt-24 lg:pt-40 pb-32 lg:pb-48 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
			<div class="lg:col-span-2 mb-8 lg:mb-0">
				<p class="mono-label animate-fade-up">— Simulacro Tech</p>
			</div>

			<div class="lg:col-span-10">
				<h1 class="text-mega text-balance">
					<span class="block animate-fade-up">{t('home.hero.title.before').trim()}</span>
					<span class="block animate-fade-up animate-delay-1 text-[var(--color-amber)]">{t('home.hero.title.highlight')}.</span>
				</h1>
			</div>
		</div>

		<div class="mt-20 lg:mt-32 grid grid-cols-1 lg:grid-cols-12 gap-10 items-end">
			<div class="lg:col-span-2 lg:col-start-3">
				<div class="rule-on-dark-strong w-12 mb-5"></div>
				<p class="mono-label">{t('home.services.label')}</p>
			</div>
			<div class="lg:col-span-7">
				<p class="text-xl lg:text-2xl text-[var(--color-text-muted)] leading-[1.4] tracking-[-0.015em] max-w-2xl text-pretty animate-fade-up animate-delay-2">
					{t('home.hero.tagline')}
				</p>
			</div>
			<div class="lg:col-span-3 flex lg:justify-end">
				<a href="#contact" class="btn btn-filled-amber animate-fade-up animate-delay-3 group">
					{t('home.hero.cta')}
					<ArrowUpRight size={16} class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
				</a>
			</div>
		</div>
	</div>

	<!-- Hard cut to the cream block below -->
	<div class="rule-on-dark-strong"></div>
</section>

<!-- ════════════════════════════════════════════════
     A position — block-cream
     The philosophical statement. Tight, Swiss.
     ════════════════════════════════════════════════ -->
<section class="block block-cream block-pad" id="position">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
			<div class="lg:col-span-3 mb-10 lg:mb-0">
				<p class="mono-label">— {t('eyebrow.position')}</p>
			</div>

			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-5xl mb-16 lg:mb-20">
					{t('home.services.heading')} —
					<span class="text-[var(--color-text-muted-on-light)]">{t('home.services.subheading')}</span>
				</h2>

				<div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-8 max-w-5xl border-t border-[var(--color-rule-dark-strong)] pt-10">
					<div>
						<p class="text-5xl lg:text-6xl font-semibold tracking-[-0.04em] leading-[0.92] mb-3">07<span class="text-[var(--color-amber-deep)]">+</span></p>
						<p class="mono-label leading-tight">{t('home.stats.years.label')}</p>
					</div>
					<div>
						<p class="text-5xl lg:text-6xl font-semibold tracking-[-0.04em] leading-[0.92] mb-3">04</p>
						<p class="mono-label leading-tight">{t('home.stats.disciplines.label')}</p>
					</div>
					<div>
						<p class="text-5xl lg:text-6xl font-semibold tracking-[-0.04em] leading-[0.92] mb-3">02</p>
						<p class="mono-label leading-tight">{t('home.stats.cities.label')}</p>
					</div>
					<div>
						<p class="text-5xl lg:text-6xl font-semibold tracking-[-0.04em] leading-[0.92] mb-3">01</p>
						<p class="mono-label leading-tight">{t('home.stats.practitioner.label')}</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     The work — block-dark
     Three work tiles. Hover = pure color swap to amber.
     ════════════════════════════════════════════════ -->
<section id="work" class="block block-dark block-pad scroll-mt-24">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('eyebrow.work')}</p>
			</div>
			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-4xl">
					{t('home.projects.heading')}.
				</h2>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[var(--color-rule-strong)]">
			{featuredProjects.map((p, i) => (
				<a
					href={`${projectsHref}#${p.id}`}
					class="group relative bg-[var(--color-bg)] hover:bg-[var(--color-amber)] transition-colors duration-500 ease-out p-8 lg:p-10 flex flex-col min-h-[18rem]"
				>
					<div class="flex items-baseline justify-between mb-12">
						<span class="mono-num text-xs tracking-widest text-[var(--color-text-muted)] group-hover:text-[var(--color-bg)]/70 transition-colors duration-500">
							N° {String(i + 1).padStart(2, '0')}
						</span>
						<ArrowUpRight size={18} class="text-[var(--color-text-muted)] group-hover:text-[var(--color-bg)] transition-colors duration-500 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" style="transition-property: color, transform;" />
					</div>

					<h3 class="text-3xl lg:text-4xl font-semibold tracking-[-0.035em] leading-[0.95] mb-auto group-hover:text-[var(--color-bg)] transition-colors duration-500">
						{p.name}
					</h3>

					<p class="text-base text-[var(--color-text-muted)] leading-[1.5] mt-12 max-w-xs text-pretty group-hover:text-[var(--color-bg)]/80 transition-colors duration-500">
						{t(p.taglineKey as UIKey)}
					</p>
				</a>
			))}
		</div>

		<div class="mt-12 flex justify-end">
			<a href={projectsHref} class="link-underline inline-flex items-center gap-2 text-[var(--color-text)] text-sm tracking-[-0.01em]">
				{t('home.projects.cta')}
				<ArrowUpRight size={14} />
			</a>
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     An approach — block-ink-blue
     Q&A. Three numbered rows, ruled list.
     ════════════════════════════════════════════════ -->
<section class="block block-ink-blue block-pad">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('eyebrow.approach')}</p>
			</div>
			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-4xl">
					{t('home.why.heading')} —
					<span class="opacity-70">{t('home.why.intro')}</span>
				</h2>
			</div>
		</div>

		<ol class="border-t border-[rgba(236,229,211,0.22)] max-w-6xl mx-auto">
			{approach.map((row, i) => {
				const num = String(i + 1).padStart(2, '0');
				return (
					<li class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 py-10 lg:py-14 border-b border-[rgba(236,229,211,0.12)]">
						<div class="lg:col-span-2 flex items-baseline gap-4">
							<span class="font-semibold text-5xl lg:text-6xl text-[var(--color-amber)] leading-none tracking-[-0.04em]">
								{num}
							</span>
						</div>
						<div class="lg:col-span-4">
							<h3 class="text-2xl lg:text-3xl font-semibold tracking-[-0.025em] leading-[1.05]">
								{t(row.titleKey)}
							</h3>
						</div>
						<div class="lg:col-span-6">
							<p class="text-base lg:text-lg leading-[1.5] opacity-80 text-pretty">
								{t(row.descKey)}
							</p>
						</div>
					</li>
				);
			})}
		</ol>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     Elsewhere — block-amber
     About preview. The amber block earns one slot.
     ════════════════════════════════════════════════ -->
<section class="block block-amber block-pad-tight overflow-hidden">
	<div class="container-shell">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center py-12 lg:py-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('eyebrow.elsewhere')}</p>
			</div>
			<div class="lg:col-span-7">
				<p class="text-2xl lg:text-3xl xl:text-4xl font-semibold tracking-[-0.03em] leading-[1.1] text-balance">
					{t('home.about.bio')}
				</p>
			</div>
			<div class="lg:col-span-2 flex lg:justify-end">
				<a href={aboutHref} class="btn btn-on-amber group">
					{t('home.about.cta')}
					<ArrowUpRight size={16} class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
				</a>
			</div>
		</div>
	</div>
</section>

<!-- ════════════════════════════════════════════════
     Contact — block-dark
     Direct, conversational. Form has flat fields.
     ════════════════════════════════════════════════ -->
<section id="contact" class="block block-dark block-pad scroll-mt-24 relative overflow-hidden">
	<div class="glow-orb w-[520px] h-[420px] -bottom-32 left-1/4"></div>

	<div class="container-shell relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
			<div class="lg:col-span-3">
				<p class="mono-label">— {t('home.contact.label')}</p>
			</div>
			<div class="lg:col-span-9">
				<h2 class="text-display leading-[0.94] tracking-[-0.04em] text-balance max-w-3xl">
					{t('home.contact.heading')}
				</h2>
				<p class="mt-8 text-lg lg:text-xl text-[var(--color-text-muted)] max-w-2xl text-pretty">
					{t('home.contact.subheading')}
				</p>
			</div>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
			<div class="lg:col-span-3 lg:col-start-4">
				<!-- spacer to align form with heading -->
			</div>
			<div class="lg:col-span-9 lg:col-start-4">
				<ContactForm lang={lang} />
			</div>
		</div>
	</div>
</section>
