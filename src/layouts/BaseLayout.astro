---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LanguageBanner from '../components/LanguageBanner.astro';
import { ui, type Lang, type UIKey } from '../i18n/ui';
import { getAlternates } from '../i18n/utils';
import '../styles/global.css';

interface Props {
	lang: Lang;
	titleKey: UIKey;
	descriptionKey: UIKey;
}

const { lang, titleKey, descriptionKey } = Astro.props;
const t = (key: UIKey) => ui[lang][key];

const siteOrigin = Astro.site ? Astro.site.origin : 'https://simulacro.tech';
const alternates = getAlternates(Astro.url.pathname, siteOrigin);

const buildDate = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={t(descriptionKey)} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/simulacro.png`} />
		{alternates.map((alt) => (
			<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
		))}
		<title>{t(titleKey)}</title>
	</head>
	<body class="overflow-x-hidden" data-build-date={buildDate}>
		<div class="min-h-screen flex flex-col relative">
			<Navigation lang={lang} />
			<main class="flex-grow">
				<slot />
			</main>
			<Footer lang={lang} buildDate={buildDate} />
		</div>

		<!-- 3.5% noise grain — composited with overlay so it reads on every block -->
		<div class="noise-overlay" aria-hidden="true"></div>

		<LanguageBanner lang={lang} />

		<script>
			// Scroll reveal — minimal observer, single class flip.
			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
					}
				});
			}, {
				threshold: 0.12,
				rootMargin: '0px 0px -60px 0px'
			});

			document.querySelectorAll('section').forEach(el => {
				el.classList.add('reveal-on-scroll');
				revealObserver.observe(el);
			});

			document.querySelectorAll('.reveal-on-scroll').forEach(el => {
				revealObserver.observe(el);
			});
		</script>
	</body>
</html>
