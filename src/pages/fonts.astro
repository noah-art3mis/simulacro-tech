---
/* Font alternatives comparison page.
   Standalone — does not load BaseLayout, so the global Bricolage default
   is overridden per-card. Each card renders the same content snippet in a
   different sans family so you can compare at scale.

   Loaded fonts come from two CDNs:
   - Google Fonts (most candidates)
   - Fontshare (Satoshi, General Sans, Cabinet Grotesk)
*/

const fonts = [
	{ id: 'bricolage', name: 'Bricolage Grotesque', label: 'current', stack: "'Bricolage Grotesque', system-ui, sans-serif", cdn: 'google', vary: "'wdth' 100, 'opsz' 96" },
	{ id: 'inter',     name: 'Inter',                stack: "'Inter', system-ui, sans-serif",                cdn: 'google' },
	{ id: 'inter-tight', name: 'Inter Tight',        stack: "'Inter Tight', system-ui, sans-serif",          cdn: 'google' },
	{ id: 'manrope',   name: 'Manrope',              stack: "'Manrope', system-ui, sans-serif",              cdn: 'google' },
	{ id: 'plex',      name: 'IBM Plex Sans',        label: 'data / technical',  stack: "'IBM Plex Sans', system-ui, sans-serif", cdn: 'google' },
	{ id: 'space',     name: 'Space Grotesk',        stack: "'Space Grotesk', system-ui, sans-serif",        cdn: 'google' },
	{ id: 'dm',        name: 'DM Sans',              stack: "'DM Sans', system-ui, sans-serif",              cdn: 'google' },
	{ id: 'geist',     name: 'Geist',                label: 'Vercel',            stack: "'Geist', system-ui, sans-serif",        cdn: 'google' },
	{ id: 'onest',     name: 'Onest',                label: 'humanist',          stack: "'Onest', system-ui, sans-serif",         cdn: 'google' },
	{ id: 'sora',      name: 'Sora',                 stack: "'Sora', system-ui, sans-serif",                  cdn: 'google' },
	{ id: 'jakarta',   name: 'Plus Jakarta Sans',    stack: "'Plus Jakarta Sans', system-ui, sans-serif",     cdn: 'google' },
	{ id: 'satoshi',   name: 'Satoshi',              label: 'Fontshare',         stack: "'Satoshi', system-ui, sans-serif",       cdn: 'fontshare' },
	{ id: 'general',   name: 'General Sans',         label: 'Söhne-like, Fontshare', stack: "'General Sans', system-ui, sans-serif", cdn: 'fontshare' },
	{ id: 'cabinet',   name: 'Cabinet Grotesk',      label: 'Fontshare',         stack: "'Cabinet Grotesk', system-ui, sans-serif", cdn: 'fontshare' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex" />
		<title>Font alternatives · Simulacro Tech</title>

		{/* Google Fonts — bundled in a single request for speed */}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75..100,300..800&family=Inter:wght@300..800&family=Inter+Tight:wght@300..800&family=Manrope:wght@300..800&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@300..700&family=DM+Sans:opsz,wght@9..40,300..900&family=Geist:wght@300..800&family=Onest:wght@300..800&family=Sora:wght@300..700&family=Plus+Jakarta+Sans:wght@300..800&family=JetBrains+Mono:wght@400;500;600&display=swap"
		/>

		{/* Fontshare — Satoshi, General Sans, Cabinet Grotesk */}
		<link
			rel="stylesheet"
			href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,600,700&f[]=general-sans@300,400,500,600,700&f[]=cabinet-grotesk@300,400,500,600,700,800&display=swap"
		/>

		<style is:global>
			:root {
				--bg: #0a0a0f;
				--bg-elev: #131319;
				--ink: #f4eedf;
				--ink-muted: #8b8678;
				--rule: rgba(244, 238, 223, 0.16);
				--rule-strong: rgba(244, 238, 223, 0.34);
				--amber: #f5b042;
				--amber-deep: #c97f2a;
				--mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
			}
			* { box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body {
				margin: 0;
				background: var(--bg);
				color: var(--ink);
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
				line-height: 1.45;
			}
			a { color: inherit; text-decoration: none; }

			.page-head {
				border-bottom: 1px solid var(--rule);
				padding: 4rem 2rem 3rem;
				max-width: 1280px;
				margin-inline: auto;
			}
			.page-head h1 {
				font-family: 'Inter Tight', system-ui, sans-serif;
				font-size: clamp(2rem, 4.5vw, 3.75rem);
				font-weight: 700;
				letter-spacing: -0.04em;
				line-height: 1;
				margin: 0 0 1rem;
			}
			.page-head p {
				color: var(--ink-muted);
				max-width: 60ch;
				margin: 0;
				font-size: 1.05rem;
			}
			.label {
				font-family: var(--mono);
				font-size: 0.7rem;
				font-weight: 500;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--ink-muted);
			}

			.toc {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1.25rem;
				margin-top: 1.5rem;
			}
			.toc a {
				font-family: var(--mono);
				font-size: 0.72rem;
				letter-spacing: 0.06em;
				color: var(--ink-muted);
				text-transform: uppercase;
				border-bottom: 1px solid transparent;
				padding-bottom: 1px;
				transition: color 0.2s, border-color 0.2s;
			}
			.toc a:hover {
				color: var(--amber);
				border-color: var(--amber);
			}

			.card {
				border-bottom: 1px solid var(--rule);
				padding: 5rem 2rem;
				max-width: 1280px;
				margin-inline: auto;
				display: grid;
				grid-template-columns: 220px 1fr;
				gap: 2.5rem;
			}
			@media (max-width: 800px) {
				.card { grid-template-columns: 1fr; padding: 3.5rem 1.5rem; }
			}

			.card-meta { display: flex; flex-direction: column; gap: 0.4rem; }
			.card-meta .name {
				font-family: var(--mono);
				font-size: 0.78rem;
				font-weight: 500;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--amber);
			}
			.card-meta .sub {
				font-family: var(--mono);
				font-size: 0.65rem;
				color: var(--ink-muted);
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			.specimen .eyebrow {
				font-family: var(--mono);
				font-size: 0.7rem;
				font-weight: 500;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--ink-muted);
				margin-bottom: 1.5rem;
				display: block;
			}
			.specimen h2 {
				font-size: clamp(2.5rem, 7vw, 6rem);
				font-weight: 700;
				letter-spacing: -0.045em;
				line-height: 0.95;
				margin: 0 0 1.25rem;
				color: var(--ink);
			}
			.specimen h2 em {
				font-style: normal;
				color: var(--amber);
			}
			.specimen .h-section {
				font-size: clamp(1.5rem, 3vw, 2.4rem);
				font-weight: 600;
				letter-spacing: -0.03em;
				line-height: 1.05;
				margin: 2.25rem 0 0.85rem;
				color: var(--ink);
			}
			.specimen .lede {
				font-size: clamp(1.05rem, 1.4vw, 1.35rem);
				color: var(--ink-muted);
				max-width: 56ch;
				line-height: 1.45;
				margin: 0 0 1.25rem;
			}
			.specimen .body {
				font-size: 1rem;
				color: var(--ink-muted);
				max-width: 64ch;
				line-height: 1.6;
				margin: 0;
			}
			.specimen .stat {
				display: flex;
				gap: 2rem;
				margin-top: 1.5rem;
				flex-wrap: wrap;
			}
			.specimen .stat span {
				font-size: clamp(2.2rem, 3.6vw, 3.25rem);
				font-weight: 600;
				letter-spacing: -0.04em;
				line-height: 0.95;
			}
			.specimen .stat span sup {
				color: var(--amber-deep);
				font-size: 0.6em;
				vertical-align: super;
			}

			footer {
				padding: 3rem 2rem 5rem;
				color: var(--ink-muted);
				font-family: var(--mono);
				font-size: 0.72rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				max-width: 1280px;
				margin-inline: auto;
				border-top: 1px solid var(--rule);
			}
		</style>
	</head>
	<body>
		<header class="page-head">
			<p class="label">— Font alternatives</p>
			<h1 style="margin-top: 0.75rem;">Sans candidates for the texture-modernist site.</h1>
			<p>
				Each card renders the same hero, section heading, lede, and stat in a different family.
				Bricolage Grotesque (the current) is at the top for reference. Loaded from Google Fonts
				and Fontshare CDNs — preview only.
			</p>

			<nav class="toc" aria-label="Font index">
				{fonts.map((f) => (
					<a href={`#${f.id}`}>{f.name}</a>
				))}
			</nav>
		</header>

		{fonts.map((f) => (
			<section class="card" id={f.id} style={`font-family: ${f.stack};`}>
				<div class="card-meta">
					<span class="name">{f.name}</span>
					{f.label && <span class="sub">{f.label}</span>}
				</div>
				<div class="specimen" style={f.vary ? `font-variation-settings: ${f.vary};` : ''}>
					<span class="eyebrow">— Approach</span>
					<h2>
						Technology<br />that serves <em>people</em>.
					</h2>
					<p class="lede">
						AI and data solutions grounded in ethics. Systems built with transparency,
						accountability, and human impact at the core.
					</p>
					<h3 class="h-section">Recent projects</h3>
					<p class="body">
						A few examples of how the practice plays out — production systems, research tools,
						end-to-end builds. Molcajete: an AI-powered transcription pipeline. Adapta:
						LLM fine-tuning infrastructure for political analysis. Judex: a Python library
						for scraping the Brazilian Supreme Court.
					</p>
					<div class="stat">
						<span>07<sup>+</sup></span>
						<span>04</span>
						<span>02</span>
					</div>
				</div>
			</section>
		))}

		<footer>
			Comparison page · /fonts · noindex
		</footer>
	</body>
</html>
